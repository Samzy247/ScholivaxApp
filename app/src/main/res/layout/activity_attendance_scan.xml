<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <View
        android:layout_width="260dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_scan_frame"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="40dp"
        android:background="#66000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="@color/white"
        android:text="Align the barcode within the frame"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E6111318">
        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:padding="20dp"
            android:text="Point the camera at a student's ID barcode"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/offlineBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@drawable/bg_pill_error"
        android:textColor="@color/error"
        android:textStyle="bold"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:visibility="gone"
        android:text="Offline — queued"/>

</FrameLayout>
