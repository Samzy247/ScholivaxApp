<?xml version="1.0" encoding="utf-8"?>
<!--
  TEMPORARY, for setup/testing: allows the app to reach a server over plain
  http:// as well as https://. Once your backend is confirmed reachable over
  HTTPS, you should remove the <base-config> block below (or set
  cleartextTrafficPermitted="false") so the app only ever uses encrypted
  connections in production.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
